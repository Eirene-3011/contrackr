# ConTrackr Backend Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env and fill in the values before running locally.
# In production (Render), set these as Environment Variables in the dashboard.

# ── Server ────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database — TiDB Cloud (MySQL-compatible) ──
# Get these from your TiDB Cloud cluster → Connect → "General" tab
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your_tidb_username.root
DB_PASSWORD=your_tidb_password
DB_NAME=contrackr_db

# ── JWT Authentication ────────────────────
# Generate a long random string: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_very_long_random_string_at_least_48_characters
JWT_EXPIRES_IN=24h

# ── Frontend URL (CORS) ───────────────────
# Set to your Netlify URL once deployed. Multiple URLs = comma-separated.
# Example: https://contrackr.netlify.app,https://www.contrackr.com
FRONTEND_URL=https://your-site.netlify.app
